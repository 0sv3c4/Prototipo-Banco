<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:fitsSystemWindows="false"
    tools:openDrawer="start"
    tools:context=".Transferencias">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- TOOLBAR SUPERIOR -->
        <include
            android:id="@+id/toolbar_superior_acc"
            layout="@layout/toolbar_superior"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- HEADER CON FONDO CURVO -->
        <FrameLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar_superior_acc">

            <View
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="-100dp"
                android:background="@drawable/bg_bottom_curve"
                android:backgroundTint="@color/ultra_claro" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="Transferencias"
                android:textAppearance="@style/titulo"
                android:textColor="@color/oscuro"
                android:textSize="32sp" />
        </FrameLayout>

        <!-- CONTENIDO SCROLLABLE -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@+id/include_bottom_toolbar"
            app:layout_constraintTop_toBottomOf="@id/header_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp">

                <!-- 1. Cuenta de origen -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/neutro"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/num1"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_circle_purple"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_toEndOf="@id/num1"
                                android:layout_centerVertical="true"
                                android:text="Cuenta de origen"
                                android:textColor="@color/neutro"
                                android:textStyle="bold"
                                android:textSize="17sp" />

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/black" />
                        </RelativeLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="40dp"
                            android:layout_marginTop="8dp"
                            android:text="C.CTE:\n3923 6783 **** **** ****"
                            android:textColor="@color/black"
                            android:textSize="17sp"
                            android:fontFamily="@font/inter_semibold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Cuenta de destino -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/neutro"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/num2"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_circle_purple"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_toEndOf="@id/num2"
                                android:layout_centerVertical="true"
                                android:text="Cuenta de destino"
                                android:textColor="@color/neutro"
                                android:textStyle="bold"
                                android:textSize="17sp" />

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/black" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="40dp"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_launcher_foreground"
                                app:tint="@color/black" />

                            <com.google.android.material.button.MaterialButton
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Destinatario de la agenda"
                                android:textAllCaps="false"
                                android:textColor="@color/neutro"
                                android:paddingVertical="4dp"
                                android:textSize="14sp"
                                app:backgroundTint="@color/ultra_claro"
                                app:cornerRadius="20dp"
                                app:strokeColor="@color/neutro"
                                app:strokeWidth="1dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="40dp"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@android:drawable/ic_input_add"
                                app:tint="@color/black" />

                            <com.google.android.material.button.MaterialButton
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Nuevo destinatario"
                                android:textAllCaps="false"
                                android:textColor="@color/neutro"
                                android:paddingVertical="4dp"
                                android:textSize="14sp"
                                app:backgroundTint="@color/ultra_claro"
                                app:cornerRadius="20dp"
                                app:strokeColor="@color/neutro"
                                app:strokeWidth="1dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Importe y Concepto -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/neutro"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/num3"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_circle_purple"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_toEndOf="@id/num3"
                                android:layout_centerVertical="true"
                                android:text="Importe y Concepto"
                                android:textColor="@color/neutro"
                                android:textStyle="bold"
                                android:textSize="17sp" />

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/black" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="40dp"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_config"
                                app:tint="@color/black" />

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/bg_rellenables"
                                android:hint="Importe"
                                android:paddingHorizontal="16dp"
                                android:textColorHint="@color/neutro"
                                android:textSize="15sp"
                                android:inputType="numberDecimal" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="40dp"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_launcher_foreground"
                                app:tint="@color/black" />

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/bg_rellenables"
                                android:hint="Concepto"
                                android:paddingHorizontal="16dp"
                                android:textColorHint="@color/neutro"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Botón Hacer Transferencia -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_hacer_transferencia"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="-10dp"
                    android:layout_marginBottom="-5dp"
                    android:fontFamily="@font/inter_bold"
                    android:text="Hacer Transferencia"
                    android:textAllCaps="false"
                    android:textSize="20sp"
                    app:backgroundTint="@color/neutro"
                    app:cornerRadius="30dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- TOOLBAR INFERIOR, BOTÓN DE VOLVER -->
        <include
            android:id="@+id/include_bottom_toolbar"
            layout="@layout/toolbar_inferior_clientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:id="@+id/nav_view"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_cabecera"
        app:menu="@menu/nav_menu"
        android:foregroundGravity="center"
        app:itemTextColor="@color/oscuro"
        app:itemTextAppearance="@style/boton_llamativo"/>

</androidx.drawerlayout.widget.DrawerLayout>