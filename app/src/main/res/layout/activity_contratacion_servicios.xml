<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:fitsSystemWindows="false"
    tools:openDrawer="start"
    tools:context=".ContratacionServicios">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- TOOLBAR SUPERIOR -->
        <include
            android:id="@+id/toolbar_superior_acc"
            layout="@layout/toolbar_superior"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- CONTENIDO SCROLLABLE -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@+id/include_bottom_toolbar"
            app:layout_constraintTop_toBottomOf="@id/toolbar_superior_acc">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <!-- HEADER CON FONDO CURVO (Dentro del scroll) -->
                <FrameLayout
                    android:id="@+id/header_container"
                    android:layout_width="match_parent"
                    android:layout_height="120dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="-100dp"
                        android:background="@drawable/bg_bottom_curve"
                        android:backgroundTint="@color/ultra_claro" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="20dp"
                        android:text="Contratación de\nServicios"
                        android:gravity="center"
                        android:textAppearance="@style/titulo"
                        android:textColor="@color/oscuro"
                        android:textSize="32sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp">

                    <!-- Sección Acciones -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Acciones"
                        android:textAppearance="@style/subtitulo"
                        android:textColor="@color/oscuro"
                        android:layout_marginTop="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_config"
                            app:tint="@color/neutro" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Seleccione su activo"
                            android:textColor="@color/neutro"
                            android:textSize="18sp" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:padding="4dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:background="@color/mas_claro"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small"
                            app:tint="@color/neutro" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Populares:"
                        android:textColor="@color/claro"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginTop="8dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Apple"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:textColor="@color/black"
                                android:paddingHorizontal="10dp"
                                app:backgroundTint="@color/mas_claro"
                                app:cornerRadius="18dp" />
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginStart="6dp"
                                android:text="Amazon"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:textColor="@color/black"
                                android:paddingHorizontal="10dp"
                                app:backgroundTint="@color/mas_claro"
                                app:cornerRadius="18dp" />
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginStart="6dp"
                                android:text="Tesla"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:textColor="@color/black"
                                android:paddingHorizontal="10dp"
                                app:backgroundTint="@color/mas_claro"
                                app:cornerRadius="18dp" />
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginStart="6dp"
                                android:text="Microsoft"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:textColor="@color/black"
                                android:paddingHorizontal="10dp"
                                app:backgroundTint="@color/mas_claro"
                                app:cornerRadius="18dp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- Espacio para el gráfico -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/grisaceo"
                        app:strokeWidth="1dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_launcher_foreground"
                            android:scaleType="centerInside" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cantidad deseada"
                                android:textColor="@color/black"
                                android:textStyle="bold" />
                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_rellenables"
                                android:hint="Num. acciones"
                                android:paddingHorizontal="12dp"
                                android:textSize="14sp"
                                android:inputType="number" />
                        </LinearLayout>
                        <View android:layout_width="16dp" android:layout_height="0dp" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Precio de acción"
                                android:textColor="@color/black"
                                android:textStyle="bold" />
                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_rellenables"
                                android:hint="Precio actual"
                                android:paddingHorizontal="12dp"
                                android:textSize="14sp"
                                android:inputType="numberDecimal" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Área Precio Final -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        app:cardBackgroundColor="@color/ultra_claro"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PRECIO FINAL"
                                android:textColor="@color/black"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00.0€"
                                android:textColor="@color/claro"
                                android:textSize="48sp"
                                android:fontFamily="@font/inter_black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="16dp"
                        android:text="Confirmar pago"
                        android:textAllCaps="false"
                        android:textSize="20sp"
                        android:fontFamily="@font/inter_bold"
                        app:backgroundTint="@color/neutro"
                        app:cornerRadius="30dp" />

                    <!-- Sección Préstamos -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Préstamos"
                        android:textAppearance="@style/subtitulo"
                        android:textColor="@color/oscuro"
                        android:layout_marginTop="32dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Para realizar un préstamo es necesario que se ponga en contacto con su oficina más cercana"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Acceda al servicio al cliente\n¡Contáctanos! 📞"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/mas_claro"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- TOOLBAR INFERIOR, BOTÓN DE VOLVER -->
        <include
            android:id="@+id/include_bottom_toolbar"
            layout="@layout/toolbar_inferior_clientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:id="@+id/nav_view"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_cabecera"
        app:menu="@menu/nav_menu"
        android:foregroundGravity="center"
        app:itemTextColor="@color/oscuro"
        app:itemTextAppearance="@style/boton_llamativo"/>

</androidx.drawerlayout.widget.DrawerLayout>
