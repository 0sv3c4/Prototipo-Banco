<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:fitsSystemWindows="false"
    tools:openDrawer="start"
    tools:context=".Pantalla_principal">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- TOOLBAR SUPERIOR -->
        <include
            android:id="@+id/toolbar_superior_acc"
            layout="@layout/toolbar_superior"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- CONTENIDO - EL LINEAR LAYOUT QUE NO SE PUEDE TOCAR (Fondo crema curvo) -->
        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:gravity="bottom|center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbar_superior_acc">

            <View
                android:id="@+id/fondo_redondo"
                android:layout_width="900dp"
                android:layout_height="550dp"
                android:background="@drawable/bg_bottom_curve" />
        </LinearLayout>

        <!-- CONTENIDO NO ESCROLLEABLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/toolbar_superior_acc"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Visibilidad de datos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|end"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visibilidad de datos"
                    android:textColor="@color/neutro"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="@font/inter_bold"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_visibilidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/neutro"/>
            </LinearLayout>

            <!-- Tarjeta Cuenta Principal - MÁS ESTRECHA ARRIBA Y ABAJO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingHorizontal="28dp"
                    android:background="@color/claro">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cuenta corriente:"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="@font/inter_bold"/>

                    <TextView
                        android:id="@+id/tv_iban"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/IBAN"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter_semibold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saldo disponible:"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter_bold"/>

                    <TextView
                        android:id="@+id/tv_saldo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.777,23€"
                        android:textColor="@color/white"
                        android:textSize="40sp"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_black"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botones de Acciones Rápidas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:weightSum="4">

                <!-- Bizum -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:padding="18dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:background="@color/mas_claro"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="@color/black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bizum"
                        android:textColor="@color/claro"
                        android:fontFamily="@font/inter_bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Balance -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:padding="18dp"
                        android:src="@drawable/ic_config"
                        android:background="@color/mas_claro"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="@color/black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Balance"
                        android:textColor="@color/claro"
                        android:fontFamily="@font/inter_bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Transferir -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:padding="18dp"
                        android:src="@drawable/ic_send_white"
                        android:background="@color/mas_claro"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="@color/black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transferir"
                        android:textColor="@color/claro"
                        android:fontFamily="@font/inter_bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Servicios -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:padding="18dp"
                        android:src="@drawable/ic_map"
                        android:background="@color/mas_claro"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="@color/black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Servicios"
                        android:textColor="@color/claro"
                        android:fontFamily="@font/inter_bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Sección Promoción -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡ Promoción temporal !"
                android:textColor="@color/neutro"
                android:gravity="center"
                android:textSize="22sp"
                android:fontFamily="@font/inter_bold"
                android:layout_marginTop="20dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="12dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/mas_claro"
                app:cardElevation="2dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/promo1"
                    android:contentDescription="Promoción temporal" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Zona NFC Inferior - ÓVALO MÁS ESTRECHO DE ARRIBA -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:clipChildren="false">

                <View
                    android:id="@+id/nfc_background_curve"
                    android:layout_width="800dp"
                    android:layout_height="500dp"
                    android:background="@drawable/bg_bottom_curve"
                    android:backgroundTint="@color/mas_claro"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/tv_nfc_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Desliza para activar el pago NFC"
                    android:textColor="@color/neutro"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:layout_marginTop="30dp"
                    app:layout_constraintTop_toTopOf="@id/nfc_background_curve"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="80dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/arrow_up_float"
                    android:background="@color/black"
                    android:padding="4dp"
                    android:layout_marginTop="15dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
                    app:layout_constraintTop_toBottomOf="@id/tv_nfc_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:tint="@color/white" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <!-- Botón volver (requerido por BaseActivityClientes, oculto aquí) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_volver"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:id="@+id/nav_view"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_cabecera"
        app:menu="@menu/nav_menu"
        android:foregroundGravity="center"
        app:itemTextColor="@color/oscuro"
        app:itemTextAppearance="@style/boton_llamativo"/>

</androidx.drawerlayout.widget.DrawerLayout>
