<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:fitsSystemWindows="false"
    tools:openDrawer="start"
    tools:context=".Pantalla_principal">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- TOOLBAR SUPERIOR -->
        <include
            android:id="@+id/toolbar_superior_acc"
            layout="@layout/toolbar_superior"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- CONTENIDO -->
        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:gravity="bottom|center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbar_superior_acc">

            <View
                android:id="@+id/fondo_redondo"
                android:layout_width="900dp"
                android:layout_height="550dp"
                android:background="@drawable/bg_bottom_curve" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!--
    <com.google.android.material.navigation.NavigationView
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:id="@+id/nav_view"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_cabecera"
        app:menu="@menu/nav_menu"
        android:foregroundGravity="center"
        app:itemTextColor="@color/oscuro"
        app:itemTextAppearance="@style/boton_llamativo"/>
        -->

</androidx.drawerlayout.widget.DrawerLayout>