<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".todosUsu.Accesibilidad"
    android:background="@color/white">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_accesibilidad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ultra_claro"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accesibilidad"
                android:textAppearance="@style/titulo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTENIDO -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/include_bottom_toolbar"
        app:layout_constraintTop_toBottomOf="@id/header_accesibilidad">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- VISIÓN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_extrabold"
                android:text="Visión"
                android:textColor="@color/black"
                android:textSize="24sp" />


            <include
                android:id="@+id/item_alto_contraste"
                layout="@layout/item_setting_switch" />

            <include
                android:id="@+id/item_texto_grande"
                layout="@layout/item_setting_switch" />

            <include
                android:id="@+id/item_reducir_movimiento"
                layout="@layout/item_setting_switch" />

            <include
                android:id="@+id/item_modo_oscuro"
                layout="@layout/item_setting_switch" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/grisaceo" />

            <!-- AUDICIÓN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/inter_extrabold"
                android:text="Audición"
                android:textColor="@color/black"
                android:textSize="24sp" />

            <include
                android:id="@+id/item_lectura_voz"
                layout="@layout/item_setting_switch" />

            <include
                android:id="@+id/item_alertas_sonoras"
                layout="@layout/item_setting_switch" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/grisaceo" />

            <!-- INTERACCIÓN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/inter_extrabold"
                android:text="Interacción"
                android:textColor="@color/black"
                android:textSize="24sp" />

            <include
                android:id="@+id/item_botones_grandes"
                layout="@layout/item_setting_switch" />

            <include
                android:id="@+id/item_vibracion_tactil"
                layout="@layout/item_setting_switch" />

            <!-- BOTÓN CENTRAL -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:text="Reestablecer ajustes predeterminados"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="@color/white"
                android:fontFamily="@font/inter_extrabold"
                app:backgroundTint="@color/claro"
                app:cornerRadius="30dp" />

            <!-- Para que se pueda ver todas las opciones-->
            <View
                android:layout_width="match_parent"
                android:layout_height="150dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- TOOLBAR INFERIOR -->
    <include
        android:id="@+id/include_bottom_toolbar"
        layout="@layout/toolbar_inferior_todos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>