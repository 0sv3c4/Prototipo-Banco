<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".todosUsu.Pantalla_inicial">

    <ImageView
        android:id="@+id/miImagen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/fondo_superior_promociones"
        android:src="@drawable/bg_titulo"
        android:translationY="-50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dk_capital_"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center_horizontal|top"
        android:text="@string/dk_capital_"
        android:textAppearance="@style/titulo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subitulo_inicio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="92dp"
        android:gravity="center_horizontal|top"
        android:text="@string/subitulo_inicio"
        android:textAppearance="@style/subtitulo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/inicio_sesion"
        android:clickable="true"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="148dp"
        android:contentDescription="Inicio de Sesión"
        android:src="@drawable/inicio_sesion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/contactanos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="252dp"
        android:contentDescription="Acceso a contacto"
        android:src="@drawable/contactanos"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Aparrtado de ofertas -->

    <TextView
        android:id="@+id/mejores_ofertas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="376dp"
        android:gravity="center_horizontal|top"
        android:text="Nuestras mejores ofertas:"
        android:textAppearance="@style/titulo_seccion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.144"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/prox_eventos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="624dp"
        android:gravity="center_horizontal|top"
        android:text="Proximos Eventos:"
        android:textAppearance="@style/titulo_seccion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.11"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Apartado de eventos -->

    <ImageView
        android:id="@+id/contenedor1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="400dp"
        android:contentDescription="contenedor de fotos para ofertas"
        android:src="@drawable/fondo_mostrador"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="353dp"
        android:layout_height="191dp"

        android:orientation="horizontal"
        android:padding="18dp"
        app:layout_constraintBottom_toBottomOf="@+id/contenedor1"
        app:layout_constraintStart_toStartOf="@+id/contenedor1">

        <!-- Tarjeta Evento 1: DK Finance Day -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_oferta_1"
            android:layout_width="99dp"
            android:layout_height="144dp"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/img_oferta_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="DK Finance Day"
                android:scaleType="centerCrop"
                android:src="@drawable/promo1" />

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Evento 2: Feria del Ahorro -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_oferta_2"
            android:layout_width="99dp"
            android:layout_height="144dp"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/img_oferta_2"
                android:layout_width="match_parent"
                android:layout_height="147dp"
                android:contentDescription="Feria del Ahorro"
                android:scaleType="centerCrop"
                android:src="@drawable/promo2" />

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Evento 3: Kong Tech Talk -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_oferta_3"
            android:layout_width="99dp"
            android:layout_height="144dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/img_oferta_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Kong Tech Talk"
                android:scaleType="centerCrop"
                android:src="@drawable/promo3" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>


    <!-- Apartado de eventos -->

    <ImageView
        android:id="@+id/contenedor2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="650dp"
        android:contentDescription="contenedor de fotos para eventos"
        android:src="@drawable/fondo_mostrador"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:layout_width="353dp"
        android:layout_height="191dp"
        android:orientation="horizontal"
        android:padding="18dp"
        app:layout_constraintBottom_toBottomOf="@+id/contenedor2"
        app:layout_constraintStart_toStartOf="@+id/contenedor2">

        <!-- Tarjeta Evento 1: DK Finance Day -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_evento_1"
            android:layout_width="99dp"
            android:layout_height="144dp"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/img_evento_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="DK Finance Day"
                android:scaleType="centerCrop"
                android:src="@drawable/evento1" />

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Evento 2: Feria del Ahorro -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_evento_2"
            android:layout_width="99dp"
            android:layout_height="144dp"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/img_evento_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Feria del Ahorro"
                android:scaleType="centerCrop"
                android:src="@drawable/evento2" />

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Evento 3: Kong Tech Talk -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_evento_3"
            android:layout_width="99dp"
            android:layout_height="144dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/img_evento_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Kong Tech Talk"
                android:scaleType="centerCrop"
                android:src="@drawable/evento3" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>