<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0F0"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Fondo curvo superior morado -->
        <View
            android:id="@+id/headerBackground"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:background="@drawable/bg_header_bizum"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Menú hamburguesa -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu"
            android:tint="@android:color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Icono campana -->
        <ImageButton
            android:id="@+id/btnNotifications"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="60dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bell"
            android:tint="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Avatar usuario -->
        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo Bizum -->
        <ImageView
            android:id="@+id/imgLogoBizum"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/ic_bizum_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Título Acciones rápidas -->
        <TextView
            android:id="@+id/tvAccionesRapidas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="Acciones rápidas:"
            android:textColor="#6A0DAD"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerBackground" />

        <!-- Botón Enviar dinero -->
        <LinearLayout
            android:id="@+id/layoutEnviar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAccionesRapidas">

            <ImageButton
                android:id="@+id/btnEnviarDinero"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_circle_purple"
                android:padding="14dp"
                android:src="@drawable/ic_send_money"
                android:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Enviar dinero"
                android:textColor="#333333"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Botón Solicitar dinero -->
        <LinearLayout
            android:id="@+id/layoutSolicitar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/layoutEnviar"
            app:layout_constraintTop_toBottomOf="@id/tvAccionesRapidas">

            <ImageButton
                android:id="@+id/btnSolicitarDinero"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_circle_purple"
                android:src="@drawable/ic_request_money"
                android:tint="@android:color/white"
                android:padding="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Solicitar dinero"
                android:textColor="#333333"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Sección Contactos recientes -->
        <TextView
            android:id="@+id/tvContactosRecientes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="Contactos recientes:"
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutEnviar" />

        <TextView
            android:id="@+id/tvVerTodos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            android:text="Ver todos →"
            android:textColor="#6A0DAD"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutEnviar" />

        <!-- Fila de contactos recientes -->
        <LinearLayout
            android:id="@+id/layoutContactos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvContactosRecientes">

            <!-- Contacto M -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/contacto1Inicial"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_light_purple"
                    android:gravity="center"
                    android:text="M"
                    android:textColor="#6A0DAD"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Manuel A."
                    android:textColor="#555555"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Contacto C -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/contacto2Inicial"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_light_purple"
                    android:gravity="center"
                    android:text="C"
                    android:textColor="#6A0DAD"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Claudia C."
                    android:textColor="#555555"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Contacto J -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/contacto3Inicial"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_light_purple"
                    android:gravity="center"
                    android:text="J"
                    android:textColor="#6A0DAD"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Juan M."
                    android:textColor="#555555"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Contacto Ó -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/contacto4Inicial"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_light_purple"
                    android:gravity="center"
                    android:text="Ó"
                    android:textColor="#6A0DAD"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Óscar T."
                    android:textColor="#555555"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Label Destinatario -->
        <TextView
            android:id="@+id/tvDestinatario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="Destinatario"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutContactos" />

        <!-- Campo Destinatario -->
        <EditText
            android:id="@+id/etDestinatario"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_input_field"
            android:hint="Introduce un contacto"
            android:hintTextColor="#AAAAAA"
            android:inputType="textPersonName"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#333333"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDestinatario" />

        <!-- Label Seleccionar cantidad -->
        <TextView
            android:id="@+id/tvCantidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:text="Seleccionar cantidad"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etDestinatario" />

        <!-- Campo Cantidad -->
        <EditText
            android:id="@+id/etCantidad"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_input_field"
            android:hint="Saldo"
            android:hintTextColor="#AAAAAA"
            android:inputType="numberDecimal"
            android:digits="0123456789.,"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#333333"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCantidad" />

        <!-- Label Concepto -->
        <TextView
            android:id="@+id/tvConcepto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:text="Concepto (opcional)"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etCantidad" />

        <!-- Campo Concepto -->
        <EditText
            android:id="@+id/etConcepto"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_input_field"
            android:hint="Escribe un mensaje..."
            android:hintTextColor="#AAAAAA"
            android:inputType="textMultiLine"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#333333"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvConcepto" />

        <!-- Botón Confirmar -->

        <!-- Botón Volver -->

        <Button
            android:id="@+id/btnConfirmar"
            android:layout_width="543dp"
            android:layout_height="45dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="208dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_button_purple"
            android:text="Confirmar"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.502"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etConcepto" />

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="631dp"
            android:layout_height="74dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_button_purple_light"
            android:text="Volver"
            android:textColor="#6A0DAD"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnConfirmar" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>