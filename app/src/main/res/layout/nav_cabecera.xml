<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="290dp"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="275dp"
        android:gravity="bottom|center">

        <View
            android:id="@+id/fondo_redondo"
            android:layout_width="500dp"
            android:layout_height="375dp"
            android:layout_marginEnd="100dp"
            android:background="@drawable/bg_cabecera_drawer" />

    </LinearLayout>


    <ImageView
        android:id="@+id/btn_menu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_menu_hamburguesa"
        android:contentDescription="Menú"
        app:tint="@color/oscuro" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/btn_perfil"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="180dp"
        android:src="@drawable/ic_cliente"
        android:padding="2dp"
        android:background="@drawable/bg_titulo"
        android:backgroundTint="@color/ultra_claro"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

    <TextView
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="25dp"
        android:layout_marginTop="70dp"
        android:text="@string/nombre_cliente"
        android:textAppearance="@style/titulo"
        android:textColor="@color/ultra_claro"
        android:textSize="35sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_saldo_nav"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/valor_saldo"
        android:layout_marginStart="25dp"
        android:layout_marginTop="170dp"
        android:textAppearance="@style/titulo"
        android:textColor="@color/claro"
        android:textSize="30sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mi perfil"
        android:layout_marginStart="50dp"
        android:layout_marginTop="220dp"
        android:textAppearance="@style/subtitulo"
        android:layout_marginBottom="16dp"/>

</FrameLayout>