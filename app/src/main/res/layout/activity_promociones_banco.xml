<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="todosUsu.Promociones_banco">

    <!-- Header Superior -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_oficina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ultra_claro"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ajustar el óvalo-->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="275dp"
        android:gravity="bottom|end"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/fondo_redondo"
            android:layout_width="600dp"
            android:layout_height="510dp"
            android:layout_marginEnd="-10dp"
            android:background="@drawable/bg_cabecera_drawer"
            android:backgroundTint="@color/ultra_claro"/>

    </LinearLayout>

    <TextView
        android:id="@+id/titulo_promociones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Promociones"
        android:layout_marginTop="20dp"
        android:layout_marginStart="30dp"
        android:textAppearance="@style/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_oficina" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Encuentra la que más te guste!"
        android:textAppearance="@style/subtitulo"
        android:textColor="@color/neutro"
        app:layout_constraintStart_toStartOf="@+id/titulo_promociones"
        app:layout_constraintTop_toBottomOf="@+id/titulo_promociones" />


    <!-- Toolbar Inferior -->
    <include
        android:id="@+id/include_bottom_toolbar"
        layout="@layout/toolbar_inferior_todos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>