<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- CAPA 1: El círculo exterior (define el tamaño final) -->
    <item>
        <shape android:shape="oval">
            <size
                android:width="100dp"
                android:height="100dp" />
            <solid android:color="@color/info" />
            <stroke
                android:width="10dp"
                android:color="@color/info" />
        </shape>
    </item>

    <item
        android:top="15dp"
        android:bottom="35dp"
        android:left="43dp"
        android:right="43dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <item
        android:top="70dp"
        android:bottom="16dp"
        android:left="43dp"
        android:right="43dp">
            <shape android:shape="oval">
                <solid android:color="@color/white" />
                <corners android:radius="2dp" />
            </shape>
    </item>



</layer-list>