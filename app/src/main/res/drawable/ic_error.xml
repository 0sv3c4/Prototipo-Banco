<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- CAPA 1: El círculo exterior (define el tamaño final) -->
    <item>
        <shape android:shape="oval">
            <size
                android:width="100dp"
                android:height="100dp" />
            <solid android:color="@color/white" />
            <stroke
                android:width="10dp"
                android:color="@color/error" />
        </shape>
    </item>

    <item
        android:top="45dp"
        android:bottom="45dp"
        android:left="15dp"
        android:right="15dp">
        <rotate
            android:fromDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="@color/error" />
                <corners android:radius="2dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:top="45dp"
        android:bottom="45dp"
        android:left="15dp"
        android:right="15dp">
        <rotate
            android:fromDegrees="-45">
            <shape android:shape="rectangle">
                <solid android:color="@color/error" />
                <corners android:radius="2dp" />
            </shape>
        </rotate>
    </item>



</layer-list>