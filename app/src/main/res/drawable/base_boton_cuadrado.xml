<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Color de relleno -->
    <solid android:color="@color/oscuro" />

    <!-- Esquinas redondeadas: cuanto mayor el radio, más redondeado -->
    <corners android:radius="8dp" />

    <!-- Borde opcional (quítalo si no lo necesitas) -->
    <stroke
        android:width="2dp"
        android:color="@color/claro" />

</shape>