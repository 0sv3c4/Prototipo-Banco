<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- CAPA 1: El círculo exterior (define el tamaño final) -->
    <item>
        <shape android:shape="oval">
            <size
                android:width="100dp"
                android:height="100dp" />
            <solid android:color="@color/white" />
            <stroke
                android:width="10dp"
                android:color="@color/exito" />
        </shape>
    </item>

    <item
        android:top="55dp"
        android:bottom="35dp"
        android:left="30dp"
        android:right="50dp">
        <rotate
            android:fromDegrees="30">
            <shape android:shape="rectangle">
                <solid android:color="@color/exito" />
                <corners android:radius="2dp" />
            </shape>
        </rotate>
    </item>

    <item
        android:top="45dp"
        android:bottom="45dp"
        android:left="35dp"
        android:right="20dp">
        <rotate
            android:fromDegrees="-60">
            <shape android:shape="rectangle">
                <solid android:color="@color/exito" />
                <corners android:radius="2dp" />
            </shape>
        </rotate>
    </item>



</layer-list>