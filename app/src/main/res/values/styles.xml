<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="titulo">
        <item name="android:textSize">40sp</item>
        <item name="android:fontFamily">"@font/inter_black"</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textColor">@color/oscuro</item>
    </style>

    <style name="subtitulo">
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textColor">#7404BF</item>
        <item name="android:fontFamily">"@font/inter_bold"</item>
    </style>

    <style name="titulo_seccion">
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textColor">@color/oscuro</item>
        <item name="android:fontFamily">"@font/inter_extrabold"</item>
    </style>

    <style name="boton_llamativo">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">"@font/inter_extrabold"</item>
    </style>

    <style name="BotonBase">
        <item name="android:background">@drawable/base_boton_cuadrado</item>
        <item name="android:textAppearance">@style/boton_llamativo</item>
        <item name="android:gravity">center</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableTint">@color/white</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">5dp</item>
        <item name="iconSize">20dp</item>
        <item name="iconTint">@color/white</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="rellenable">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <style name="cuadrado_rellenable">
        <item name="android:background">@drawable/bg_rellenables</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:textAppearance">@style/rellenable</item>
        <item name="android:textColor">@color/grisaceo</item>
    </style>

</resources>